import { Button, Switch, ComboBox, GroupBox, VerticalBox, HorizontalBox, ScrollView, TabWidget, CheckBox, Slider } from "std-widgets.slint";

export struct DeviceToggle {
    name: string,
    description: string,
    excluded: bool,
}

export component LogWindow inherits Window {
    title: "Application Logs";
    icon: @image-url("assets/icon.png");
    min-width: 600px;
    min-height: 400px;

    in property <string> log_text: "";
    in-out property <string> log_search: "";
    callback refresh_logs();

    VerticalBox {
        spacing: 10px;
        padding: 10px;
        HorizontalBox {
            spacing: 10px;
            Text { text: "Search Logs:"; vertical-alignment: center; font-size: 12px; }
            TextInput {
                text: log_search;
                edited => {
                    log_search = self.text;
                    refresh_logs();
                }
            }
            Button {
                text: "Refresh";
                clicked => { refresh_logs(); }
            }
        }
        Rectangle {
            border-radius: 4px;
            border-color: #ddd;
            border-width: 1px;
            background: #fafafa;
            vertical-stretch: 1;
            ScrollView {
                viewport-height: log_text_item.preferred-height;
                log_text_item := Text {
                    padding: 10px;
                    text: log_text;
                    wrap: word-wrap;
                    font-size: 11px;
                    font-family: "monospace";
                }
            }
        }
    }
}

export component AppWindow inherits Window {
    title: l_title;
    icon: @image-url("assets/icon.png");
    
    min-width: 500px;
    min-height: 450px;

    // Callbacks
    callback refresh();
    callback sink_changed(int);
    callback source_changed(int);
    callback toggle_bluetooth(bool);
    callback toggle_unified(bool);
    callback toggle_filter(bool);
    callback toggle_device_exclusion(string, bool);
    callback toggle_hide_unknown_bt(bool);
    callback sink_volume_changed(int);
    callback open_logs();
    callback run_diagnostics();
    callback uninstall_app();
    callback install_app();
    callback open_url(string);

    // Localization properties
    in property <string> l_title: "Audio Selector";
    in property <string> l_tab_devices: "Devices";
    in property <string> l_advanced_options: "Advanced Options";
    in property <string> l_tab_about: "About";
    in property <string> l_hide_unknown_bt: "Hide unknown Bluetooth devices (MACs)";
    in property <string> l_bluetooth: "Bluetooth";
    in property <string> l_unified: "Use same device for input/output";
    in property <string> l_output: "Output Device";
    in property <string> l_input: "Input Device";
    in property <string> l_audio_device: "Audio Device";
    in property <string> l_refresh: "Refresh Devices";
    in property <string> l_filter_active: "Enable Excluded Devices";
    in property <string> l_exclude_instruction: "Check devices below to hide them from the main list:";
    in property <string> l_volume: "Volume";
    in property <string> l_open_logs: "Open Application Logs";
    in property <string> l_dev_info: "Developer: Evandro Jr";
    in property <string> l_github: "GitHub";
    in property <string> l_website: "Website";
    in property <string> l_install_prompt: "Would you like to install?";
    in property <string> l_install_now: "Install Now";
    in property <string> l_maybe_later: "Maybe Later";
    in property <string> l_run_diagnostics: "Run System Diagnostics";
    in property <string> l_diag_title: "System Diagnostics";
    in property <string> l_diag_pactl: "PulseAudio Tool (pactl)";
    in property <string> l_diag_btctl: "Bluetooth Tool (bluetoothctl)";
    in property <string> l_diag_audio_svc: "Audio Service (Pulse/PipeWire)";
    in property <string> l_diag_bt_svc: "Bluetooth Service (bluez)";
    in property <string> l_uninstall: "Uninstall Application";
    in property <string> l_uninstall_confirm: "Are you sure?";
    in property <string> l_uninstall_now: "Uninstall Now";
    in property <string> l_diag_ok: "OK";
    in property <string> l_diag_missing: "MISSING";
    in property <string> l_diag_inactive: "INACTIVE";

    in property <[string]> sink_names: [];
    in property <[string]> source_names: [];
    in property <[DeviceToggle]> all_devices: [];
    in property <string> status: "Ready";
    in property <bool> bluetooth_available: true;
    in-out property <bool> show_install_prompt: false;
    in-out property <bool> show_uninstall_prompt: false;
    in-out property <bool> show_diag_results: false;
    in property <string> diag_pactl_status: "OK";
    in property <string> diag_btctl_status: "OK";
    in property <string> diag_audio_svc_status: "OK";
    in property <string> diag_bt_svc_status: "OK";
    
    in-out property <int> selected_sink_index: -1;
    in-out property <int> selected_source_index: -1;
    in-out property <bool> unified_mode: true;
    in-out property <bool> bluetooth_enabled: false;
    in-out property <bool> filter_enabled: false;
    in-out property <bool> hide_unknown_bt: false;
    in-out property <int> sink_volume: 50;

    VerticalBox {
        spacing: 15px;
        padding: 10px;

        TabWidget { 
            Tab {
                title: l_tab_devices;
                ScrollView {
                    VerticalBox {
                        spacing: 15px;
                        padding: 10px;

                        HorizontalBox {
                            alignment: space-between;
                            Text { text: l_bluetooth; vertical-alignment: center; }
                            Switch {
                                checked: bluetooth_enabled;
                                enabled: bluetooth_available;
                                toggled => {
                                    bluetooth_enabled = !bluetooth_enabled;
                                    toggle_bluetooth(bluetooth_enabled);
                                }
                            }
                        }

                        HorizontalBox {
                            alignment: space-between;
                            Text { text: l_unified; vertical-alignment: center; }
                            Switch {
                                checked: unified_mode;
                                toggled => {
                                    unified_mode = !unified_mode;
                                    toggle_unified(unified_mode);
                                }
                            }
                        }

                        // Device Selectors
                        GroupBox {
                            title: unified_mode ? l_audio_device : l_output;
                            VerticalBox {
                                spacing: 15px;
                                ComboBox {
                                    model: sink_names;
                                    current-index <=> selected_sink_index;
                                    selected => {
                                        sink_changed(selected_sink_index);
                                    }
                                }

                                HorizontalBox {
                                    spacing: 10px;
                                    Text { 
                                        text: l_volume + ": " + sink_volume + "%"; 
                                        vertical-alignment: center; 
                                        width: 100px;
                                    }
                                    Slider {
                                        minimum: 0;
                                        maximum: 100;
                                        value: sink_volume;
                                        changed(val) => {
                                            sink_volume = val;
                                            sink_volume_changed(val);
                                        }
                                    }
                                }
                            }
                        }

                        if !unified_mode : GroupBox {
                            title: l_input;
                            ComboBox {
                                model: source_names;
                                current-index <=> selected_source_index;
                                selected => {
                                    source_changed(selected_source_index);
                                }
                            }
                        }

                        // Refresh button only in the devices tab
                        HorizontalBox {
                            alignment: center;
                            padding-top: 10px;
                            Button {
                                text: l_refresh;
                                clicked => { refresh(); }
                            }
                        }
                    }
                }
            }

            Tab {
                title: l_advanced_options;
                ScrollView {
                    VerticalBox {
                        spacing: 15px;
                        padding: 10px;

                        HorizontalBox {
                            alignment: space-between;
                            Text { text: l_hide_unknown_bt; vertical-alignment: center; }
                            Switch {
                                checked: hide_unknown_bt;
                                toggled => {
                                    hide_unknown_bt = !hide_unknown_bt;
                                    toggle_hide_unknown_bt(hide_unknown_bt);
                                }
                            }
                        }

                        HorizontalBox {
                            alignment: space-between;
                            Text { text: l_filter_active; vertical-alignment: center; font-weight: 700; }
                            Switch {
                                checked: filter_enabled;
                                toggled => {
                                    filter_enabled = !filter_enabled;
                                    toggle_filter(filter_enabled);
                                }
                            }
                        }

                        if filter_enabled : VerticalBox {
                            spacing: 10px;
                            Text { text: l_exclude_instruction; font-size: 12px; }
                            
                            Rectangle {
                                border-radius: 4px;
                                border-color: #ddd;
                                border-width: 1px;
                                background: #fafafa;
                                min-height: 150px;
                                ScrollView {
                                    VerticalBox {
                                        spacing: 5px;
                                        padding: 10px;
                                        for dev in all_devices : CheckBox {
                                            text: dev.description;
                                            checked: dev.excluded;
                                            toggled => {
                                                toggle_device_exclusion(dev.name, self.checked);
                                            }
                                        }
                                    }
                                }
                            }
                        }

                        VerticalBox {
                            padding: 10px;
                            spacing: 10px;
                            Button {
                                text: l_run_diagnostics;
                                clicked => { run_diagnostics(); }
                            }
                            Button {
                                text: l_open_logs;
                                clicked => { open_logs(); }
                            }
                            Button {
                                text: l_uninstall;
                                clicked => { show_uninstall_prompt = true; }
                            }
                        }
                    }
                }
            }

            Tab {
                title: l_tab_about;
                VerticalBox {
                    spacing: 20px;
                    padding: 20px;
                    alignment: center;
                    
                    Image {
                        source: @image-url("assets/icon.png");
                        width: 100px;
                        height: 100px;
                    }
                    
                    Text {
                        text: l_title;
                        font-size: 20px;
                        font-weight: 700;
                        horizontal-alignment: center;
                    }
                    
                    Text {
                        text: "v1.9.2";
                        font-size: 14px;
                        color: #666;
                        horizontal-alignment: center;
                    }
                    
                    Text {
                        text: l_dev_info;
                        font-size: 14px;
                        horizontal-alignment: center;
                    }
                    
                    HorizontalBox {
                        alignment: center;
                        spacing: 15px;
                        Button {
                            text: l_github;
                            clicked => { open_url("https://github.com/evandrojr/audio-selector"); }
                        }
                        Button {
                            text: l_website;
                            clicked => { open_url("https://evandrojr.github.io/audio-selector/"); }
                        }
                    }
                    
                    Rectangle { vertical-stretch: 1; }
                }
            }
        }

        // Status Area
        Rectangle {
            background: #f0f0f0;
            border-radius: 4px;
            height: 35px;
            Text {
                text: status;
                color: #555;
                font-italic: true;
                vertical-alignment: center;
                horizontal-alignment: center;
                overflow: elide;
            }
        }
    }

    if show_diag_results : Rectangle {
        background: #00000088;
        TouchArea { } 
        
        Rectangle {
            width: 350px;
            height: diag_vbox.preferred-height;
            background: white;
            border-radius: 8px;
            border-width: 1px;
            border-color: #ccc;
            
            diag_vbox := VerticalBox {
                padding: 20px;
                spacing: 15px;
                
                Text {
                    text: l_diag_title;
                    font-size: 18px;
                    font-weight: 700;
                    horizontal-alignment: center;
                }
                
                VerticalBox {
                    spacing: 10px;
                    
                    HorizontalBox {
                        alignment: space-between;
                        Text { text: l_diag_pactl; }
                        Text { 
                            text: diag_pactl_status; 
                            color: diag_pactl_status == l_diag_ok ? green : red;
                            font-weight: 700;
                        }
                    }
                    HorizontalBox {
                        alignment: space-between;
                        Text { text: l_diag_btctl; }
                        Text { 
                            text: diag_btctl_status; 
                            color: diag_btctl_status == l_diag_ok ? green : red;
                            font-weight: 700;
                        }
                    }
                    HorizontalBox {
                        alignment: space-between;
                        Text { text: l_diag_audio_svc; }
                        Text { 
                            text: diag_audio_svc_status; 
                            color: diag_audio_svc_status == l_diag_ok ? green : red;
                            font-weight: 700;
                        }
                    }
                    HorizontalBox {
                        alignment: space-between;
                        Text { text: l_diag_bt_svc; }
                        Text { 
                            text: diag_bt_svc_status; 
                            color: diag_bt_svc_status == l_diag_ok ? green : red;
                            font-weight: 700;
                        }
                    }
                }
                
                Button {
                    text: "OK";
                    clicked => { show_diag_results = false; }
                }
            }
        }
    }

    if show_uninstall_prompt : Rectangle {
        background: #00000088;
        TouchArea { } 
        
        Rectangle {
            width: 350px;
            height: uninstall_vbox.preferred-height;
            background: white;
            border-radius: 8px;
            border-width: 1px;
            border-color: #ccc;
            
            uninstall_vbox := VerticalBox {
                padding: 20px;
                spacing: 15px;
                
                Text {
                    text: l_uninstall;
                    font-size: 18px;
                    font-weight: 700;
                    horizontal-alignment: center;
                }
                
                Text {
                    text: l_uninstall_confirm;
                    wrap: word-wrap;
                    horizontal-alignment: center;
                }
                
                HorizontalBox {
                    spacing: 15px;
                    alignment: center;
                    Button {
                        text: l_uninstall_now;
                        clicked => {
                            show_uninstall_prompt = false;
                            uninstall_app();
                        }
                    }
                    Button {
                        text: l_maybe_later;
                        clicked => {
                            show_uninstall_prompt = false;
                        }
                    }
                }
            }
        }
    }

    if show_install_prompt : Rectangle {
        background: #00000088;
        TouchArea { } 
        
        Rectangle {
            width: 350px;
            height: install_vbox.preferred-height;
            background: white;
            border-radius: 8px;
            border-width: 1px;
            border-color: #ccc;
            
            install_vbox := VerticalBox {
                padding: 20px;
                spacing: 15px;
                
                Text {
                    text: l_title;
                    font-size: 18px;
                    font-weight: 700;
                    horizontal-alignment: center;
                }
                
                Text {
                    text: l_install_prompt;
                    wrap: word-wrap;
                    horizontal-alignment: center;
                }
                
                HorizontalBox {
                    spacing: 15px;
                    alignment: center;
                    Button {
                        text: l_install_now;
                        primary: true;
                        clicked => {
                            show_install_prompt = false;
                            install_app();
                        }
                    }
                    Button {
                        text: l_maybe_later;
                        clicked => {
                            show_install_prompt = false;
                        }
                    }
                }
            }
        }
    }
}
